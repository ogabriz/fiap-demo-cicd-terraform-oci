					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{api_key}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"flag_name\": \"enable-new-dashboard\",\n    \"is_enabled\": true,\n    \"rules\": {\n        \"type\": \"PERCENTAGE\",\n        \"value\": 50\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/target/rules",
							"host": ["{{base_url}}"],
							"path": ["target", "rules"]
						}
					}
				}
			]
		},
