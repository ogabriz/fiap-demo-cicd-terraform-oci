								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"enable-new-dashboard\",\n    \"description\": \"Habilita o novo dashboard de controle\",\n    \"is_enabled\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/flags/flags",
							"host": ["{{base_url}}"],
							"path": ["flags", "flags"]
						}
					}
				},
				{
					"name": "List All Flags (GET)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{api_key}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/flags/flags",
							"host": ["{{base_url}}"],
							"path": ["flags", "flags"]
						}
					}
				}
			]
		},
		{
			"name": "Targeting Service (Regras)",
			"item": [
