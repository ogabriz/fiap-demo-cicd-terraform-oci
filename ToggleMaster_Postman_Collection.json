			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/evaluate/health",
							"host": ["{{base_url}}"],
							"path": ["evaluate", "health"]
						}
					}
				},
				{
					"name": "Evaluate Dashboard (User 123)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/evaluate/evaluate?user_id=user-123&flag_name=enable-new-dashboard",
							"host": ["{{base_url}}"],
							"path": ["evaluate", "evaluate"],
							"query": [
								{ "key": "user_id", "value": "user-123" },
								{ "key": "flag_name", "value": "enable-new-dashboard" }
							]
						}
					}
				},
				{
					"name": "Evaluate Dashboard (User ABC)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/evaluate/evaluate?user_id=user-abc&flag_name=enable-new-dashboard",
							"host": ["{{base_url}}"],
							"path": ["evaluate", "evaluate"],
							"query": [
								{ "key": "user_id", "value": "user-abc" },
								{ "key": "flag_name", "value": "enable-new-dashboard" }
							]
						}
					}
				}
			]
		}
